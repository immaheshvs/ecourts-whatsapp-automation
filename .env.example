# ===============================================
# eCourts WhatsApp Automation - Environment Setup
# ===============================================
# Copy this file as .env and fill in all values

# ==================== eCourts API ====================
# Get from https://ecourtsindia.com/api/docs
ECOURTS_API_KEY=your_ecourts_api_key_here

# ==================== MongoDB ====================
# Get free MongoDB at https://www.mongodb.com/cloud/atlas
# Connection string format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@your-cluster.mongodb.net/ecourts-db?retryWrites=true&w=majority

# ==================== Twilio (for WhatsApp) ====================
# Get free $15 credit at https://www.twilio.com/try-twilio
# After signup, go to Twilio Console to find Account SID and Auth Token
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio WhatsApp sender number (usually +1XXXXXXXXXXXX from Twilio)
# You'll get this from Twilio WhatsApp Sandbox when you set it up
TWILIO_WHATSAPP_NUMBER=+1234567890

# ==================== Your Details ====================
# Your WhatsApp number where you want to receive alerts
# Format: +91XXXXXXXXXX (for India)
USER_PHONE=+919876543210

# Server port (default 3000, Render/Railway will override this)
PORT=3000

# ==================== Node Environment ====================
NODE_ENV=production
